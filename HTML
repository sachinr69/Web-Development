<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        table{
            width: 100%;
            border-collapse: collapse;
            text-align: center;
            color: rgb(116, 9, 16);
        }
        td , th{
            border: 1px solid black;
            padding: 10px
        }
        tr:nth-child(even) {
            background-color: white;
        }
    </style>
</head>
<body>
    <table>
        <tr>
            
        </tr>
        <tr>
            <td>India</td>
