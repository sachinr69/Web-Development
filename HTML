<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>My List</h1>
    <h2>Unordered List</h2>
    <ul>
        <li>1</li>
        <li>2</li>
        <li>3</li>
        <li>4</li>
        <li>5</li>
        <li>6</li>
    </ul>
    <h2>Ordered list
    </h2>
    <ol type="i">
    <li>One</li>
    <li>Two</li>
    <li>Three</li>
    </ol>
    <dl>
        <dt>TEA</dt>
        <dd>chai</dd>
        <dd>lemon tea</dd>
        <dd>hot tea</dd>
        <dd>kullad tea</dd>
    </dl>
    
</body>
</html>
